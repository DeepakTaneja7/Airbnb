<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb</title>
</head>
<body>
    <h3>Create New Listing</h3>
    <form method="POST" action="/listings">
        <label for="title">Title : </label>
        <input type="text" name="listing[title]" id="title" required>
        <br><br>
        <label for="description">Description : </label>
        <textarea name="listing[description]" id="description" cols="20" rows="2" required></textarea>
        <br><br>
        <label for="image">Image URL : </label>
        <input type="text" name="listing[image]" id="image" >
        <br><br>
        <label for="price">Price : </label>
        <input type="number" name="listing[price]" id="price" required>
        <br><br>
        <label for="location">Location : </label>
        <input type="text" name="listing[location]" id="location" required>
        <br><br>
        <label for="country">Country : </label>
        <input type="text" name="listing[country]" id="country" required>
        <br><br>
        <button>Create Listing</button>

    </form>
    
</body>
</html>